    "shaderSpeed": 0.3,
    "description": "Experimental multi-pass shader. BUG: If your OS (<a href=\"https://www.windowscentral.com/how-set-custom-display-scaling-setting-windows-10\" target=\"change_windows_screen_scale\">Windows</a>, Mac, Linux) does scale your screen then this shader will not work correctly!",
    "buffers": [
        {
            "shaderName": "LHCBufferA.frag",
            "output": 0
        },
        {
            "shaderName": "LHCBufferB.frag",
            "output": 1,
            "iChannel0": "buffer0"
        }
    ],
    "iChannel0": "buffer1"
}
