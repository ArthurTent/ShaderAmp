{
    "name": "ShaderAmp",
    "version": "2.0.0",
    "description": "Unofficial ShaderToy Chrome Extension to visualize sound of any page.",
    "manifest_version": 3,
    "options_page": "options.html",
    "background": {
        "service_worker": "js/backgroundPage.js",
        "scripts": ["js/backgroundPage.js"]
    },
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "tabCapture",
        "offscreen"
    ],
    "host_permissions": [
        "https://www.shadertoy.com/*",
        "https://shadertoy.com/*",
        "http://localhost:11434/*",
        "http://127.0.0.1:11434/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://www.shadertoy.com/view/*", "https://shadertoy.com/view/*"],
            "js": ["js/shadertoyContent.js"],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_icon": {
            "32": "images/icon32.png",
            "64": "images/icon64.png",
            "128": "images/icon128.png",
            "256": "images/icon256.png",
            "512": "images/icon512.png"
        },
        "default_popup": "popup.html",
        "default_title": "ShaderAmp 2.0.0"
    },
    "icons": {
        "32": "images/icon32.png",
        "64": "images/icon64.png",
        "128": "images/icon128.png",
        "256": "images/icon256.png",
        "512": "images/icon512.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+K"
            }
        },
        "open-shader-amp": {
            "suggested_key": {
                "default": "Ctrl+Shift+L"
            },
            "description": "Open ShaderAmp"
        },
        "open-shader-amp-options": {
            "suggested_key": {
                "default": "Ctrl+Shift+O"
            },
            "description": "Open ShaderAmp Options window"
        }
    },
    "web_accessible_resources": [
        {
            "resources": ["media/*", "add-ons/monaco/**/*", "third_party_licenses.md"],
            "matches": ["<all_urls>"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "shaderamp@arthurtent.github.io",
            "strict_min_version": "128.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "data_collection_permissions": {
        "none": true
    }
}
